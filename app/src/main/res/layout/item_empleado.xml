<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/blanco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar placeholder -->
        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="👤"
            android:textSize="28sp"
            android:gravity="center"
            android:layout_marginEnd="12dp" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreEmpleado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textColor="@color/gris_oscuro"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmailEmpleado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@ejemplo.com"
                android:textColor="@color/gris_medio"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvEstadoEmpleado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Activo"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Switch activo/inactivo -->
        <Switch
            android:id="@+id/swActivo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="@color/verde_primario"
            android:trackTint="@color/verde_claro" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
